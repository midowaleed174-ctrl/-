rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Logic: User is admin if they exist in the 'admins' collection
      // Bootstrap Owner: wmido976@gmail.com
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'wmido976@gmail.com'
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUserProfile(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
               data.uid == userId &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 200 &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.photoURL is string && data.photoURL.size() <= 1000 &&
               data.role in ['user', 'admin', 'owner'];
      }

      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && (
        incoming().role == 'user' || isAdmin()
      );
      
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Update Profile (User updates their own details, but cannot change role)
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'createdAt'])) ||
        // Action: Admin updates role
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']))
      ) && isValidUserProfile(incoming());
    }

    // --- Appointments ---
    match /appointments/{appointmentId} {
      function isValidAppointment(data) {
        return data.keys().hasAll(['userId', 'serviceId', 'day', 'time', 'patientName', 'patientPhone', 'status', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.status == 'pending' &&
               data.patientName is string && data.patientName.size() <= 100 &&
               data.patientPhone is string && data.patientPhone.size() <= 20 &&
               data.day is string && data.day.size() <= 20;
      }

      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isEmailVerified() && isValidAppointment(incoming()) && isValidId(appointmentId);
      
      allow update: if isAdmin() && (
        // Action: Approve/Reject/Cancel
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'cancellationReason'])) ||
        // Action: Re-schedule/Edit
        (incoming().diff(existing()).affectedKeys().hasAny(['day', 'time', 'date', 'price']))
      );
      
      allow delete: if isAdmin();
    }

    // --- Inquiries ---
    match /inquiries/{inquiryId} {
      function isValidInquiry(data) {
        return data.keys().hasAll(['userId', 'message', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.message is string && data.message.size() <= 2000;
      }

      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isEmailVerified() && isValidInquiry(incoming());
      
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['response', 'respondedAt']);
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // --- Configuration Collections ---
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dentists/{dentistId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offDays/{offDayId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Admins Registry ---
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
